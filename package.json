{
  "name": "patchwork-app",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --port 19000 --tunnel --clear",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "jest"
  },
  "jest": {
    "projects": [
      {
        "displayName": "node",
        "testEnvironment": "node",
        "transform": {
          "^.+\\.(ts|tsx|js|jsx)$": [
            "babel-jest",
            {
              "presets": [
                [
                  "@babel/preset-env",
                  {
                    "targets": {
                      "node": "current"
                    }
                  }
                ],
                "@babel/preset-typescript"
              ]
            }
          ]
        },
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/$1"
        },
        "testMatch": [
          "<rootDir>/__tests__/**/*.test.ts"
        ],
        "testPathIgnorePatterns": [
          "/node_modules/",
          "/.expo/",
          "/dist/"
        ]
      },
      {
        "displayName": "rn",
        "preset": "jest-expo",
        "setupFiles": [
          "<rootDir>/jest.setup.js"
        ],
        "moduleNameMapper": {
          "^@/(.*)$": "<rootDir>/$1"
        },
        "testMatch": [
          "<rootDir>/__tests__/**/*.test.tsx"
        ],
        "transformIgnorePatterns": [
          "node_modules/(?!((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-reanimated|react-native-worklets|@react-native-async-storage|jotai))"
        ]
      }
    ]
  },
  "dependencies": {
    "@expo/ngrok": "^4.1.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.22",
    "expo-image-picker": "~17.0.11",
    "expo-linking": "~8.0.12",
    "expo-localization": "~17.0.8",
    "expo-media-library": "~18.2.1",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-screen-orientation": "~9.0.9",
    "expo-sqlite": "~16.0.10",
    "expo-status-bar": "~3.0.9",
    "i18next": "^26.0.8",
    "jotai": "^2.19.1",
    "polygon-clipping": "^0.15.7",
    "react": "19.1.0",
    "react-i18next": "^17.0.6",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-worklets": "0.5.1",
    "svg-path-properties": "^2.0.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-typescript": "^7.28.5",
    "@testing-library/react-native": "^13.3.3",
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "babel-jest": "^30.3.0",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.4",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "jest": "^30.3.0",
    "jest-expo": "~54.0.17",
    "prettier": "^3.8.3",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
