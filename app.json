{
  "expo": {
    "name": "Patchwork",
    "slug": "patchwork-app",
    "scheme": "patchwork",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.example.patchworkapp",
      "infoPlist": {
        "NSCameraUsageDescription": "布地を撮影してパッチワーク作成に使用するためにカメラを使用します。",
        "NSPhotoLibraryUsageDescription": "登録する布地画像を選ぶためにフォトライブラリにアクセスします。",
        "NSPhotoLibraryAddUsageDescription": "作成したパッチワーク画像をフォトライブラリに保存するためのアクセス許可です。"
      }
    },
    "android": {
      "package": "com.example.patchworkapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "登録する布地画像を選ぶためにフォトライブラリにアクセスします。",
          "cameraPermission": "布地を撮影してパッチワーク作成に使用するためにカメラを使用します。"
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "作成したパッチワーク画像をフォトライブラリに保存します。",
          "savePhotosPermission": "作成したパッチワーク画像をフォトライブラリに保存します。",
          "isAccessMediaLocationEnabled": false
        }
      ]
    ]
  }
}
